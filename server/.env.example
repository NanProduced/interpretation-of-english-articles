APP_NAME="AI 英语文章解读服务"
APP_ENV="development"
LOG_LEVEL="INFO"

DEFAULT_MODEL_PROFILE=""
PREPROCESS_MODEL_PROFILE=""
CORE_MODEL_PROFILE=""
TRANSLATION_MODEL_PROFILE=""

# 必填：通过 JSON 声明可用 profile。
# provider / model / route 默认值完全解耦，后续新增模型时只追加 profile 即可。
# 例如：
# MODEL_PROFILES_JSON='{"local_qwen":{"provider":"openai_compatible","model_name":"Qwen/Qwen3-8B","base_url":"http://127.0.0.1:8000/v1","api_key":"","model_settings":{"temperature":0.1}},"minimax_m27":{"provider":"openai_compatible","model_name":"MiniMax-M2.7","base_url":"https://api.minimax.io/v1","api_key":"your-minimax-key"}}'
MODEL_PROFILES_JSON=""

# 可选：定义服务端可复用的命名路由 preset。
# 例如：
# MODEL_PRESETS_JSON='{"minimax_eval":{"routes":{"analysis_core":{"profile":"minimax_m27"},"analysis_translation":{"profile":"minimax_m27"}}}}'
MODEL_PRESETS_JSON=""

LANGSMITH_ENABLED="false"
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="english-article-interpretation-dev"
LANGSMITH_API_KEY=""
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_WORKSPACE_ID=""
# OTel 模式由应用启动时自动启用，无需手动配置 LANGSMITH_OTEL_ENABLED
