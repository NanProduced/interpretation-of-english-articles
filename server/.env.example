# 可选：定义服务端可复用的命名路由 preset。
# 例如：
# MODEL_PRESETS_JSON='{"minimax_eval":{"routes":{"analysis_core":{"profile":"minimax_m27"},"analysis_translation":{"profile":"minimax_m27"}}}}'
