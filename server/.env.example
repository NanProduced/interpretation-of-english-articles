APP_NAME="AI 英语文章解读服务"
APP_ENV="development"
LOG_LEVEL="INFO"

# 数据库（PostgreSQL）
DATABASE_URL="postgresql://claread:claread_dev@127.0.0.1:5432/claread"
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_MAX_INACTIVE_CONNECTION_LIFETIME=3600

# Redis（可选，第二阶段增强；当前为 False，不阻塞启动）
REDIS_URL="redis://127.0.0.1:6379/0"
REDIS_ENABLED=false

# 微信认证（必填，小程序正式上线需要）
# 请在微信公众平台获取 AppID 和 AppSecret
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# Session 有效期（天）
AUTH_SESSION_EXPIRY_DAYS=30

DEFAULT_MODEL_PROFILE=""
ANNOTATION_MODEL_PROFILE=""

# 必填：通过 JSON 声明可用 profile。
# 支持两种方式：
# 1. 外部 JSON 文件（推荐）：MODEL_PROFILES_JSON="config/model-profiles.json"
# 2. 内联 JSON：MODEL_PROFILES_JSON="{\"profile_name\":{...}}"
# 详细说明见：docs/operations/model-configuration-usage.md
MODEL_PROFILES_JSON=""

# 可选：定义服务端可复用的命名路由 preset。
# 支持外部 JSON 文件或内联 JSON。
# 例如：MODEL_PRESETS_JSON="config/model-presets.json"
MODEL_PRESETS_JSON=""

LANGSMITH_ENABLED="false"
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="english-article-interpretation-dev"
LANGSMITH_API_KEY=""
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_WORKSPACE_ID=""
# OTel 模式由应用启动时自动启用，无需手动配置 LANGSMITH_OTEL_ENABLED
